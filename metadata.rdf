    <schema:dateModified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-19</schema:dateModified>
    <schema:datePublished rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-06-17</schema:datePublished>
    <schema:description>Diese OER führt in die Erstellung von QUADRIGA-OERs ein, bietet Inhalte für Nutzer:innen der OERs und dient gleichzeitig als Template für die Erstellung eigener OERs auf Basis der QUADRIGA-Empfehlungen.</schema:description>
    <schema:funding>Die vorliegenden Open Educational Resources wurden durch das Datenkompetenzzentrum QUADRIGA erstellt.

Förderkennzeichen: 16DKZ2034</schema:funding>
    <schema:hasPart>
      <schema:LearningResource rdf:about="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_0">
        <schema:description>Beschreibung der Lernziele und technischer Voraussetzungen der Fallstudie.</schema:description>
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_0_objective_0" />
        <schema:name>Präambel</schema:name>
        <schema:teaches>Die Teilnehmenden verstehen die Lernziele und technischen Voraussetzungen der Fallstudie.</schema:teaches>
        <schema:timeRequired>PT1M</schema:timeRequired>
        <schema:url rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/präambel/einführung.html" />
      </schema:LearningResource>
    </schema:hasPart>
    <schema:hasPart>
      <schema:LearningResource rdf:about="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_1">
        <schema:description>Dieses Kapitel bildet den Auftakt der Fallstudie und dient der Klärung des Erkenntnisinteresses, das die dann folgende Vorbereitung und Aufbereitung des Forschungsgegenstands (Korpus) und schließlich die Analyse leitet.</schema:description>
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_1_objective_0" />
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_1_objective_1" />
        <schema:name>Fragestellung und Operationalisierung. Einführung in die Fallstudie</schema:name>
        <schema:teaches>Grundlagen korpusbasierter geisteswissenschaftlicher Forschung</schema:teaches>
        <schema:timeRequired>45min</schema:timeRequired>
        <schema:url rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/research_question/research-question_intro.html" />
      </schema:LearningResource>
    </schema:hasPart>
    <schema:hasPart>
      <schema:LearningResource rdf:about="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_2">
        <schema:description>Der Forschungsgegenstand wird in Form eines Korpus aufbereitet.</schema:description>
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_2_objective_0" />
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_2_objective_1" />
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_2_objective_2" />
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_2_objective_3" />
        <schema:name>Korpusaufbau. Auswählen, sammeln, dokumentieren</schema:name>
        <schema:teaches>Ansätze des Korpusaufbaus und Erstellung basaler Metadaten</schema:teaches>
        <schema:timeRequired>90min</schema:timeRequired>
        <schema:url rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/corpus_collection/corpus-collection_intro.html" />
      </schema:LearningResource>
    </schema:hasPart>
    <schema:hasPart>
      <schema:LearningResource rdf:about="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_3">
        <schema:description>In diesem Kapitel lernen wir, wie man mit OCR Bilder in Text umwandelt.</schema:description>
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_3_objective_0" />
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_3_objective_1" />
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_3_objective_2" />
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_3_objective_3" />
        <schema:name>OCR. Von Bild zu Text</schema:name>
        <schema:teaches>OCR-basierte Korpuserstellung und Qualitätsbewertung</schema:teaches>
        <schema:timeRequired>120min</schema:timeRequired>
        <schema:url rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/ocr/ocr_intro.html" />
      </schema:LearningResource>
    </schema:hasPart>
    <schema:hasPart>
      <schema:LearningResource rdf:about="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_4">
        <schema:description>In diesem Kapitel werden wir die Ergebnisse der OCR nachbearbeiten.</schema:description>
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_4_objective_0" />
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_4_objective_1" />
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_4_objective_2" />
        <schema:name>OCR-Nachbearbeitung: manuell, automatisch, LLMs</schema:name>
        <schema:teaches>OCR-Nachbearbeitung und Qualitätsverbesserung</schema:teaches>
        <schema:timeRequired>90min</schema:timeRequired>
        <schema:url rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/ocr_post_correction/post-correcting_intro.html" />
      </schema:LearningResource>
    </schema:hasPart>
    <schema:hasPart>
      <schema:LearningResource rdf:about="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_5">
        <schema:description>Die im Korpus enthaltenen Textdateien werden mit linguistischen Informationen angereichert.</schema:description>
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_5_objective_0" />
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_5_objective_1" />
        <schema:name>Korpusverarbeitung. Von Strings zu Token</schema:name>
        <schema:teaches>Korpusverarbeitung mit Natural Language Processing</schema:teaches>
        <schema:timeRequired>60min</schema:timeRequired>
        <schema:url rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/corpus_processing/corpus-processing_intro.html" />
      </schema:LearningResource>
    </schema:hasPart>
    <schema:hasPart>
      <schema:LearningResource rdf:about="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_6">
        <schema:description>Nachdem die Korpuserstellung und -anreicherung abgeschlossen ist, wird in diesem Kapitel zur Forschungsfrage zurückgekehrt. Es soll die öffentliche Aufmerksamkeit für die spanische Grippe im Zeitaum von 1918-1920 an Hand von Worthäufigkeiten derjenigen Wörter gemessen werden, die direkt oder indirekt auf die spanische Grippe verweisen.</schema:description>
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_6_objective_0" />
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_6_objective_1" />
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_6_objective_2" />
        <schema:name>Korpusanalyse. Von Häufigkeiten zu Diagrammen</schema:name>
        <schema:teaches>Frequenzanalysen semantischer Felder</schema:teaches>
        <schema:timeRequired>90min</schema:timeRequired>
        <schema:url rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/corpus_analysis/corpus-analysis_intro.html" />
      </schema:LearningResource>
    </schema:hasPart>
    <schema:hasPart>
      <schema:LearningResource rdf:about="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_7">
        <schema:description>Auch wenn es uns gelungen ist, das Ziel der Fallstudie zu erreichen und unsere eingangs formulierte Forschungsfrage nach den "Medienwellen" der Spanischen Grippe insofern exemplarisch zu beantworten, als wir tatsächliche eine wellenartige Entwicklung der quantitative verstandenen Aufmerksamkeit in ausgewählten Berliner Tageszeitungen nachweisen konnten, gibt es mehrere Punkte, die abschließend kritisch zu reflektieren sind.</schema:description>
        <schema:educationalAlignment rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/#chapter_7_objective_0" />
        <schema:name>Reflexion</schema:name>
        <schema:teaches>Kritische Bewertung der Reichweite und Limitationen</schema:teaches>
        <schema:timeRequired>30min</schema:timeRequired>
        <schema:url rdf:resource="https://quadriga-dk.github.io/Text-Fallstudie-1/reflection/reflection_reflection.html" />
      </schema:LearningResource>
    </schema:hasPart>
